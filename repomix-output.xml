  openModal() {
    this.showAddModal = true;
  }

  closeModal() {
    this.showAddModal = false;
    this.itemForm.reset();
  }

  onSubmit() {
    if (this.itemForm.invalid) return;

    this.itemService.createItem(this.itemForm.value).subscribe({
      next: (newItem) => {
        this.items.unshift(newItem);
        this.closeModal();
        this.cdr.detectChanges();
      }
    });
  }
}
